{
  "version": "1.0.0",
  "requiredDocs": [
    "README.md",
    "AGENT.md",
    "contributing_ai.md",
    "doc/Architecture-Folder-Governance.md",
    "doc/Product-Standards.md",
    "doc/Test-Standards.md",
    "doc/Roadmap.md",
    "doc/plans/README.md",
    "doc/plans/archive/README.md",
    "reports/README.md",
    "config/governance/product_boundary_truth.json",
    "config/governance/doc_code_consistency_rules.json",
    "config/governance/architecture_exceptions.json",
    "config/governance/runtime_write_registry.json"
  ],
  "exceptionRegistry": "config/governance/architecture_exceptions.json",
  "requiredDirs": [
    "src",
    "server",
    "shared",
    "plugins/autodesign",
    "plugins/autodesign-smoke",
    "scripts",
    "doc",
    "reports",
    "config/governance",
    "schemas"
  ],
  "maxFileLines": {
    "default": 800,
    "hard": 2000
  },
  "dependencyRules": [
    {
      "scope": "shared",
      "forbid": [
        "../server/",
        "../src/",
        "../plugins/",
        "../../server/",
        "../../src/",
        "../../plugins/"
      ]
    },
    {
      "scope": "server",
      "forbid": [
        "../plugins/",
        "../src/",
        "../../plugins/",
        "../../src/"
      ]
    },
    {
      "scope": "src",
      "forbid": [
        "../server/",
        "../plugins/",
        "../../server/",
        "../../plugins/"
      ]
    },
    {
      "scope": "plugins",
      "forbid": [
        "../server/",
        "../src/",
        "../../server/",
        "../../src/",
        "../../../server/",
        "../../../src/"
      ]
    },
    {
      "scope": "scripts",
      "forbid": [
        "../server/",
        "../src/",
        "../plugins/",
        "../../server/",
        "../../src/",
        "../../plugins/"
      ]
    }
  ]
}
