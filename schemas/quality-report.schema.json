{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodesign.local/schema/quality-report.json",
  "type": "object",
  "required": [
    "kind",
    "timestamp",
    "scope",
    "owner",
    "inputs",
    "measurements",
    "findings"
  ],
  "properties": {
    "kind": {
      "const": "quality_report"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "follow_up": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
