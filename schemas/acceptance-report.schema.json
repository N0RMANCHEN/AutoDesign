{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodesign.local/schema/acceptance-report.json",
  "type": "object",
  "required": [
    "kind",
    "timestamp",
    "status",
    "scope",
    "owner",
    "scenario",
    "steps",
    "observations"
  ],
  "properties": {
    "kind": {
      "const": "acceptance_report"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}$"
    },
    "status": {
      "enum": ["PENDING", "PASS", "FAIL"]
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "follow_up": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
